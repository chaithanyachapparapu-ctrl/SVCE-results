rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Students collection: public get-only (for result lookups), no client list/writes
    match /students/{hallTicket} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    // Visits collection: create-only (for visitor tracking), no client reads/updates/deletes
    match /visits/{visitId} {
      allow create: if request.resource.data.keys().hasOnly([
        'ip', 'userAgent', 'language', 'platform',
        'screenResolution', 'windowSize', 'timestamp'
      ]);
      allow read, update, delete: if request.auth != null;
    }

    // Searches collection: create-only (for search tracking), no client reads/updates/deletes
    match /searches/{searchId} {
      allow create: if request.resource.data.keys().hasOnly([
        'hallTicket', 'semester', 'examType', 'resultFound', 'timestamp'
      ]);
      allow read, update, delete: if request.auth != null;
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
